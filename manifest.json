{
  "manifest_version": 3,
  "name": "Twitch Bonus Chest Auto-Clicker",
  "version": "1.0.0",
  "description": "Automatically claims the Twitch bonus point chest while you're watching a stream.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.twitch.tv/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["selectors.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
